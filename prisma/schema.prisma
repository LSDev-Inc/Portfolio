generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum ChatSender {
  VISITOR
  ADMIN
  SYSTEM
}

enum ExperienceType {
  WORK
  EDUCATION
  CERTIFICATION
  MILESTONE
}

enum ProjectStatus {
  LIVE
  IN_PROGRESS
  ARCHIVED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(ADMIN)
  image        String?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSettings {
  id                 String   @id @default(cuid())
  ownerName          String
  professionalTitle  String
  headline           String
  heroKicker         String
  heroDescription    String   @db.Text
  about              String   @db.Text
  location           String
  email              String
  availability       String
  cvUrl              String
  primaryCtaLabel    String
  primaryCtaHref     String
  secondaryCtaLabel  String
  secondaryCtaHref   String
  githubUrl          String?
  linkedinUrl        String?
  twitterUrl         String?
  websiteUrl         String?
  accentName         String
  onlineStatus       Boolean  @default(true)
  seoTitle           String
  seoDescription     String   @db.Text
  ogImage            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SkillCategory {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  order       Int      @default(0)
  skills      Skill[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id          String        @id @default(cuid())
  name        String
  level       Int
  description String?
  featured    Boolean       @default(false)
  order       Int           @default(0)
  categoryId  String
  category    SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId])
}

model Project {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  category    String
  status      ProjectStatus @default(LIVE)
  summary     String        @db.Text
  description String        @db.Text
  impact      String
  role        String
  client      String?
  imageUrl    String
  images      String[]
  stack       String[]
  demoUrl     String?
  repoUrl     String?
  featured    Boolean       @default(false)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Experience {
  id           String         @id @default(cuid())
  title        String
  organization String
  type         ExperienceType @default(WORK)
  location     String?
  startDate    DateTime
  endDate      DateTime?
  current      Boolean        @default(false)
  summary      String         @db.Text
  highlights   String[]
  order        Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  company   String?
  subject   String
  message   String        @db.Text
  status    MessageStatus @default(UNREAD)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatConversation {
  id             String             @id @default(cuid())
  visitorId      String             @unique
  visitorName    String?
  visitorEmail   String?
  status         ConversationStatus @default(OPEN)
  unreadAdmin    Int                @default(0)
  unreadVisitor  Int                @default(0)
  lastMessageAt  DateTime           @default(now())
  messages       ChatMessage[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         ChatSender
  body           String           @db.Text
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
}

model Note {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String    @db.Text
  content     String    @db.Text
  imageUrl    String?
  tags        String[]
  published   Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
